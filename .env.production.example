NODE_ENV="production"
PORT=4000
JWT_SECRET="replace-with-a-long-random-production-secret"

# Public URL of the hosted server, used by the Vite web build and Godot Web launch.
VITE_API_URL="https://your-quizstrike-server.example.com"
VITE_API_FALLBACK_URL="https://gyakuteneigo-api.onrender.com"

# Use "/" for a custom domain, or "/your-repo-name/" for default GitHub Pages project hosting.
VITE_BASE_PATH="/"

# Comma-separated list of allowed hosted frontend origins.
CLIENT_ORIGIN="https://gyakuteneigo.com,https://www.gyakuteneigo.com,https://susume.github.io"

# Set to true when hosted behind a reverse proxy such as Render, Railway, Fly, or Nginx.
TRUST_PROXY="true"

# Required in production. The server start command applies committed migrations before listening.
DATABASE_URL="postgresql://user:password@host:5432/quizstrike?schema=public"
